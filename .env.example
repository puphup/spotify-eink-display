# Spotify Developer App credentials
# Register at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:5000/callback

# Flask
FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Display
EINK_WIDTH=800
EINK_HEIGHT=480
DISPLAY_REFRESH_INTERVAL=5

# Set to true when developing on non-Pi hardware (saves PNG instead of writing to hardware)
EINK_MOCK=true

# Optional: Spotify playlist ID to add requests to (leave blank to use queue)
SONG_REQUEST_PLAYLIST_ID=

# Guest requests on by default
GUEST_REQUESTS_ENABLED=true
